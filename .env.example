# ──────────────────────────────────────────────
# Local Development Environment Variables
# Copy this file to .env and fill in the values
#
#   cp .env.example .env
# ──────────────────────────────────────────────

# ── General ───────────────────────────────────
ENVIRONMENT=local
LOG_LEVEL=INFO
AWS_REGION=ap-south-1
SKIP_AUTH=true

# ── AWS Credentials (local/mock) ─────────────
# These are dummy credentials for DynamoDB Local & LocalStack.
# Replace with real AWS credentials for production/staging.
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# ── Storage Backend ───────────────────────────
# "dynamodb" requires Docker infra running (see README)
# "memory" uses in-memory storage (no Docker needed, data lost on restart)
STORAGE_BACKEND=dynamodb

# ── DynamoDB Local ────────────────────────────
DYNAMODB_ENDPOINT_URL=http://localhost:8000

# ── LocalStack (SNS/SQS) ─────────────────────
SNS_ENDPOINT_URL=http://localhost:4566
SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:000000000000:rural-credit-events

# ── Cross-Service URLs (local dev) ───────────
PROFILE_SERVICE_URL=http://localhost:8001
LOAN_SERVICE_URL=http://localhost:8002
RISK_SERVICE_URL=http://localhost:8003
CASHFLOW_SERVICE_URL=http://localhost:8004
EARLY_WARNING_SERVICE_URL=http://localhost:8005
GUIDANCE_SERVICE_URL=http://localhost:8006

# ── Field-Level Encryption ────────────────────
# Generate a new key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=GKUHGqvp0eIm9o_SuPk_Jbt25rV4pHc4IWE2bGbNGgE=

# ── Auth / Cognito (disabled locally) ────────
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_SKIP_VERIFICATION=true

# ── External APIs (optional for local dev) ───
WEATHER_API_KEY=
MARKET_API_URL=

# ── AI / LLM Provider ───────────────────────
# Options: "stub" (hardcoded responses), "groq" (real AI, free tier), "bedrock" (AWS)
#
# To use real AI with Groq (recommended, free):
#   1. Sign up at https://console.groq.com
#   2. Create an API key
#   3. Set LLM_PROVIDER=groq and paste the key below
#
# To run without an API key, set LLM_PROVIDER=stub (uses canned responses)
LLM_PROVIDER=groq
GROQ_API_KEY=<your-groq-api-key-here>
GROQ_MODEL_ID=llama-3.3-70b-versatile
USE_STUB_LLM=false

# ── ML Model Activation ─────────────────────
USE_ML_RISK_MODEL=true
RISK_MODEL_LOCAL_DIR=ml-pipeline/models/risk_scoring/artefacts

USE_ML_CASHFLOW_MODEL=true
CASHFLOW_MODEL_LOCAL_DIR=ml-pipeline/models/cashflow_prediction/artefacts

USE_ML_WARNING_MODEL=true
WARNING_MODEL_LOCAL_DIR=ml-pipeline/models/early_warning/artefacts

USE_ML_SCENARIO_MODEL=true
